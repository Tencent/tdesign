{
  "name": "@tdesign/theme-generator",
  "version": "1.2.5",
  "license": "MIT",
  "description": "TDesign主题配置生成器挂件",
  "scripts": {
    "dev": "vite",
    "build:css": "node scripts/build-tdesign-css.mjs",
    "build": "npm run build:css && vite build",
    "build:watch": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .vue,.js --fix"
  },
  "main": "dist/td-theme-generator.js",
  "files": [
    "dist/td-theme-generator.js"
  ],
  "keywords": [
    "tdesign",
    "theme",
    "generator"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tencent/tdesign.git",
    "directory": "packages/theme-generator"
  },
  "homepage": "https://github.com/Tencent/tdesign/blob/main/packages/theme-generator/README.md",
  "dependencies": {
    "cssbeautify": "^0.3.1",
    "lodash": "^4.17.21",
    "tdesign-icons-vue-next": "^0.4.4",
    "tdesign-vue-next": "^1.20.3",
    "tvision-color": "^1.6.0",
    "vue": "^3.5.25"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^2.1.8",
    "@vue/test-utils": "^2.4.6",
    "eslint-plugin-vue": "^9.32.0",
    "happy-dom": "^15.11.7",
    "less": "^4.2.0",
    "vite": "^6.3.1",
    "vitest": "^2.1.8",
    "vue-eslint-parser": "^9.4.2"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}
